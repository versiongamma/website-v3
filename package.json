{
  "name": "full-stack-template-react",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "prod:build": "docker compose build",
    "prod:start": "docker compose up -d",
    "prod:deploy": "bun prod:build && bun prod:start"
  },
  "dependencies": {
